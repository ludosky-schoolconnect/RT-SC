# ─── RT-SC Cloud Functions · environment ──────────────────────
# Copy this file to `.env` (for local emulator) or use
# `firebase functions:secrets:set` to store secrets in production.
# `.env` is .gitignored — never commit real secrets.

# FedaPay webhook secret — the HMAC key used to verify that incoming
# webhook POSTs actually come from FedaPay (not a spoofer).
# Get it from your FedaPay dashboard → API → Webhook secrets.
# Per-school: each school has its own FedaPay account and secret.
FEDAPAY_WEBHOOK_SECRET=

# Resend API key — transactional email provider.
# Get it from https://resend.com/api-keys.
# Single key shared across all schools (one Resend account, many
# "from" addresses). If schools want their own sender domain, each
# needs to verify it in Resend first.
RESEND_API_KEY=

# "From" email address for transactional emails.
# Must be on a domain you've verified in Resend.
# Example: "SchoolConnect <no-reply@schoolconnect.bj>"
EMAIL_FROM=

# Number of months added per subscription payment. Defaults to 1.
# Used by the FedaPay webhook when extending the deadline.
SUBSCRIPTION_MONTHS_PER_PAYMENT=1
