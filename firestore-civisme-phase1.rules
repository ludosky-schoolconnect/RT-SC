// ────────────────────────────────────────────────────────────
// RT-SC · Firestore Rules — Phase 1 (Civisme v3 catalog)
//
// MERGE these into your main firestore.rules file. They go inside
// `match /databases/{database}/documents { ... }`.
//
// Reasoning:
//   - Catalog is school-wide, read-visible to anyone signed in
//     (admins manage; students/parents/profs all browse it in
//      Phase 2/3 contexts)
//   - Writes are admin-only — caissier and prof cannot manage
//     the catalog. This matches your existing isAdmin() helper.
//
// Assumes the existing helpers in your rules file:
//   - isSignedIn()
//   - isAdmin()  (matches by email or uid per your config)
// ────────────────────────────────────────────────────────────

match /recompenses/{recompenseId} {
  // Anyone signed in can browse the catalog
  allow read: if isSignedIn();

  // Only admin (or SaaSMaster) can create/update/delete
  allow create, update, delete: if isAdmin() || isSaaSMaster();
}
