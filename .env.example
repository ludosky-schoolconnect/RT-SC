# RT-SC · Firebase environment variables
# Copy this file to `.env.local` and adjust if needed.
# .env.local is git-ignored and only loaded by Vite at dev/build time.
#
# These values are taken from the legacy firebase-config.js — same project.
# If you ever rotate keys or migrate to a new Firebase project, update them here.

VITE_FB_API_KEY=AIzaSyBIsAMHy0QiQwTDZoKAgNkKaCC54oiddAg
VITE_FB_AUTH_DOMAIN=schoolconnect-1adfa.firebaseapp.com
VITE_FB_PROJECT_ID=schoolconnect-1adfa
VITE_FB_STORAGE_BUCKET=schoolconnect-1adfa.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=31919643114
VITE_FB_APP_ID=1:31919643114:web:825c0ff537d1aee93aba93
VITE_FB_DATABASE_URL=https://schoolconnect-1adfa-default-rtdb.europe-west1.firebasedatabase.app

# Your personal Firebase Auth UID — used to gate the À propos CMS editor.
# To find it: Firebase Console → Authentication → Users → click your row → copy "User UID".
# Leave empty until you set it; the editor will be inaccessible to everyone in the meantime.
VITE_OWNER_UID=
