rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    // 🔐 SECURITY FUNCTIONS
    // ══════════════════════════════════════════════════════════

    // A logged-in Teacher, Admin or Caissier (non-anonymous auth).
    function isStaff() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Explicitly an Admin (role stored on their Professeur doc).
    function isAdmin() {
      return isStaff()
        && get(/databases/$(database)/documents/professeurs/$(request.auth.uid)).data.role == 'admin';
    }

    // Explicitly a Caissier (Phase 6d). Caissiers have a narrower
    // write surface than admins — they can record paiements, create
    // élèves via the guichet finalize flow, and triage pre-inscriptions.
    // They CANNOT delete classes, edit profs, run rollover, etc.
    function isCaissier() {
      return isStaff()
        && get(/databases/$(database)/documents/professeurs/$(request.auth.uid)).data.role == 'caissier';
    }

    // 👑 SaaS creator — bypasses school hierarchy.
    //
    // Phase 6g change: we compare UID, not email. An attacker who
    // gets access to Ludosky's email (password recovery, email
    // verification bypass) could previously become SaaSMaster. UIDs
    // are cryptographically bound to an account and can't be
    // swapped the same way. The UID below is Ludosky's Firebase
    // Auth UID — must be replaced per-school deployment if Ludosky
    // uses different credentials on different projects (unlikely
    // since he uses the same email everywhere, but the UID is
    // per-project so each school has its own).
    //
    // DEPLOYMENT NOTE: every school's rules file needs the correct
    // SaaS master UID for that school's Firebase project. Set during
    // onboarding after Ludosky logs in once to mint his UID.
    function isSaaSMaster() {
      return request.auth != null
        && request.auth.uid == 'ARCosTxTeZYvk9cj548mnRzaYKG2';
    }

    // Student identity via handshake.
    function isStudentOf(classeId, eleveId) {
      return request.auth != null
        && get(/databases/$(database)/documents/classes/$(classeId)/eleves/$(eleveId)).data.active_session_uid == request.auth.uid;
    }

    // Parent identity via handshake.
    function isParentOf(classeId, eleveId) {
      return request.auth != null
        && get(/databases/$(database)/documents/classes/$(classeId)/eleves/$(eleveId)).data.active_parent_session_uid == request.auth.uid;
    }

    // ══════════════════════════════════════════════════════════
    // 🔍 COLLECTION GROUP READS
    // ══════════════════════════════════════════════════════════

    // Parent Portal: searches every class for the passkey match.
    match /{path=**}/eleves/{eleveId} {
      allow read: if true;
    }

    // Staff-wide reads. Caissier can read notes/bulletins/absences so
    // global counters + bilans work; they'll only write paiements.
    match /{path=**}/notes/{noteId}         { allow read: if isStaff(); }
    match /{path=**}/bulletins/{bulletinId} { allow read: if isStaff(); }
    match /{path=**}/absences/{absenceId}   { allow read: if isStaff(); }
    match /{path=**}/paiements/{paiementId} { allow read: if isStaff(); }

    // ══════════════════════════════════════════════════════════
    // 🏫 SCHOOL CONFIG & GLOBAL SETTINGS
    // ══════════════════════════════════════════════════════════

    // ──────────────────────────────────────────────────────────
    // 🔒 ecole/subscription — THE CORE SAAS DOC
    // ──────────────────────────────────────────────────────────
    //
    // Phase 6g Turn 1 — locked down properly.
    //
    // Fields and who owns them:
    //
    //   deadline                     → SaaSMaster ONLY
    //   isManualLock                 → SaaSMaster ONLY
    //   fedaPayPublicKey             → SaaSMaster ONLY
    //   subscriptionPrice            → SaaSMaster ONLY
    //   subscriptionDurationMonths   → SaaSMaster ONLY
    //   supportWhatsAppNumber        → SaaSMaster ONLY
    //   hasRequestedUnlock           → Admin CAN set to true
    //                                  SaaSMaster CAN set to false (or true)
    //
    // This means:
    //   - An admin CANNOT extend their own deadline via F12
    //   - An admin CANNOT toggle isManualLock off
    //   - An admin CANNOT swap the FedaPay key (e.g. to point at
    //     their own sandbox account to get "free" payments credited)
    //   - An admin CAN tap "Signaler un paiement externe" which flips
    //     hasRequestedUnlock to true (and only to true — they can't
    //     flip it back to false themselves)
    //
    // FedaPay payments will be handled by a Cloud Function webhook
    // in Phase 6g Turn 2 (the function runs with admin SDK privilege
    // and bypasses rules). Until that ships, deadline extensions
    // happen ONLY via the vendor app (where Ludosky manually clicks
    // "Paiement reçu" after verifying the FedaPay dashboard).
    //
    // This rule MUST come BEFORE the /ecole/{document=**} catch-all
    // below. Firestore rules are FIRST-MATCH for path patterns; a
    // more specific path wins.

    // ══════════════════════════════════════════════════════════
    // 🚨🚨🚨  TEMPORARY INSECURE RULE — REVERT BEFORE DEPLOY  🚨🚨🚨
    // ══════════════════════════════════════════════════════════
    //
    // Ludosky doesn't have a Blaze-eligible card yet, so we can't
    // deploy the FedaPay webhook Cloud Function. Without that
    // webhook, LockedPage has to write `deadline` from the client
    // (the F12-bypassable path) for auto-unlock to work during
    // localhost testing.
    //
    // This rule REVERTS the Phase 6g Turn 1 hardening. Admins can
    // once again write ANY field on ecole/subscription, including
    // `deadline` → the business model is bypassable via DevTools.
    //
    // On localhost, that doesn't matter — Ludosky is the only user.
    //
    // BEFORE DEPLOYING TO A REAL SCHOOL:
    //   1. Get a debit card and enable Firebase Blaze
    //   2. Build & deploy the FedaPay webhook Cloud Function (Phase
    //      6g Turn 2). The function uses admin SDK privileges to
    //      write deadlines server-side from verified FedaPay events.
    //   3. REVERT this rule to the strict version (see the comment
    //      block immediately below for what it should look like).
    //   4. Revert src/routes/locked/LockedPage.tsx to the
    //      hasRequestedUnlock-only flow (see its 🚨 comment block
    //      at the top).
    //   5. Re-read 🚨 SECURITY-TODO-BEFORE-DEPLOY.md in the repo root
    //      before running `firebase deploy`.
    //
    // Reference for the strict (secure) rule this replaces:
    // ----------------------------------------------------------
    //   match /ecole/subscription {
    //     allow read: if true;
    //     allow write: if isSaaSMaster();
    //     allow create: if isAdmin()
    //       && request.resource.data.keys().hasOnly(['hasRequestedUnlock'])
    //       && request.resource.data.hasRequestedUnlock == true;
    //     allow update: if isAdmin()
    //       && request.resource.data.diff(resource.data).affectedKeys()
    //          .hasOnly(['hasRequestedUnlock'])
    //       && request.resource.data.hasRequestedUnlock == true;
    //     allow delete: if isSaaSMaster();
    //   }
    // ----------------------------------------------------------

    match /ecole/subscription {
      allow read: if true;
      allow write: if isAdmin() || isSaaSMaster();
    }

    // All other /ecole/* docs — admin writable (config, ecole/config
    // identity, etc.) These are school-operational settings, not SaaS
    // billing state.
    match /ecole/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isSaaSMaster();
    }

    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isSaaSMaster();
    }

    // Inscription config — public reads for form population, admin
    // writes only (caissier doesn't configure categories/materiel).
    match /settings_inscription/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isSaaSMaster();
    }

    // ══════════════════════════════════════════════════════════
    // 📝 PRE-INSCRIPTIONS (public form + admin triage + guichet)
    // ══════════════════════════════════════════════════════════

    match /pre_inscriptions/{piId} {
      allow create: if true;
      allow read: if true;

      allow update: if isStaff() || (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['dateRV', 'reprogCount']) &&
        resource.data.statut == 'Approuvé' &&
        request.resource.data.reprogCount == resource.data.reprogCount + 1
      );

      allow delete: if isAdmin();

      match /documents/{docId} {
        allow create: if true;
        allow read, write: if isStaff();
      }
    }

    // RV counter docs — integer counters for rendezvous slots. Kept
    // write-open for unauth (parents need to bump these when booking).
    // Low-stakes data; the rate limiting sits on pre_inscriptions.
    //
    // TODO Phase 6g Turn 2: tighten to "anyone can write but ONLY to
    // increment by +1, no deletions". Current risk: an attacker could
    // spam-write random values causing double-booking noise. Medium
    // priority but not bleeding.
    match /rv_counters/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // ══════════════════════════════════════════════════════════
    // 🗂️ ARCHIVES
    // ══════════════════════════════════════════════════════════

    match /archived_absences/{id} {
      allow read: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /archive/{annee} {
      allow read: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();

      match /{path=**} {
        allow read: if isStaff();
        allow write: if isAdmin();
      }
    }

    // ══════════════════════════════════════════════════════════
    // 🏫 SCHOOL-WIDE COLLECTIONS
    // ══════════════════════════════════════════════════════════

    match /classes/{document=**} {
      allow read: if true;
      allow write: if isStaff() && !isCaissier();
    }
    match /annonces/{document=**} {
      allow read: if true;
      allow write: if isStaff() && !isCaissier();
    }
    match /annonces_globales/{document=**} {
      allow read: if true;
      allow write: if isStaff() && !isCaissier();
    }
    match /school_codes/{document=**} {
      allow read: if true;
      allow write: if isStaff() && !isCaissier();
    }
    match /emploisDuTemps/{document=**} {
      allow read: if true;
      allow write: if isStaff() && !isCaissier();
    }
    match /seances/{document=**} {
      allow read: if true;
      allow write: if isStaff() && !isCaissier();
    }
    match /annales/{document=**} {
      allow read: if true;
      allow write: if isStaff() && !isCaissier();
    }
    match /vigilance_ia/{document=**} {
      allow read: if isStaff();
      allow write: if isStaff() && !isCaissier();
    }

    // Parent directory — locked to staff only (Phase 6g Turn 1 fix).
    //
    // Previously (Phase 6d): `request.auth != null && !isCaissier()`
    // which allowed ANY authenticated user (including anonymous-
    // authed eleves) to create/update parent directory entries.
    // Anonymous auth is how eleves log in, so in effect an eleve
    // could forge parent directory entries.
    //
    // Now: only staff (admin + prof, NOT caissier or eleve) can
    // write. Students shouldn't be editing their own parent's
    // contact info.
    match /annuaire_parents/{docId} {
      allow read: if request.auth != null;

      allow create, update: if isStaff()
        && !isCaissier()
        && request.resource.data.eleveId != null
        && (docId == request.resource.data.eleveId + '_parent1'
            || docId == request.resource.data.eleveId + '_parent2');

      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // 👨‍🎓 STUDENT & PARENT PROFILES — the handshake zone
    // ══════════════════════════════════════════════════════════
    //
    // NOTE re Phase 6g audit finding #6: the handshake here lets any
    // authenticated user (including anon-auth) set active_session_uid
    // to their own UID. The PIN check that GATES this is in app code
    // (client-side), which is F12-bypassable.
    //
    // Short-term mitigation: left as-is, because moving PIN
    // verification to a Cloud Function is a Turn 2 task. The blast
    // radius is limited — an attacker can impersonate an eleve whose
    // ID they already know, but can't enumerate eleveIds (the docs
    // require classId + eleveId and the eleveId is a random Firestore
    // ID, not guessable). Still a hole, just not an immediate "game
    // over" one.
    //
    // Turn 2 plan: move PIN + parent-code verification to a callable
    // Cloud Function that mints a custom token. The client calls the
    // function with (classId, eleveId, PIN), the server checks PIN
    // + parent code against the eleve doc, and returns a custom token
    // with `eleveId: XXX` claim. The client uses the token for auth
    // and rules check the custom claim instead of
    // `active_session_uid`. No more client-side PIN check.

    match /classes/{classeId}/eleves/{eleveId} {
      allow read: if true;

      // Handshake self-updates (session UIDs + english streak).
      allow update: if (
        request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active_session_uid'])
        && request.resource.data.active_session_uid == request.auth.uid
      ) || (
        request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active_parent_session_uid'])
        && request.resource.data.active_parent_session_uid == request.auth.uid
      ) || (
        request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['englishStreak', 'lastEnglishQuiz'])
      );

      // Staff writes. Caissier's only legit élève write is CREATE
      // (guichet finalize). Edit/delete is admin+prof (their tabs
      // own that workflow).
      allow create: if isStaff();
      allow update: if isStaff() && !isCaissier();
      allow delete: if isStaff() && !isCaissier();

      // ─── Private subcollections ────────────────────────────

      match /absences/{document=**} {
        allow read: if isStudentOf(classeId, eleveId)
                    || isParentOf(classeId, eleveId)
                    || isStaff();

        allow create: if (isStaff() && !isCaissier())
                      || isStudentOf(classeId, eleveId)
                      || isParentOf(classeId, eleveId);

        allow update, delete: if isStaff() && !isCaissier();
      }

      match /paiements/{document=**} {
        allow read: if isStudentOf(classeId, eleveId)
                    || isParentOf(classeId, eleveId)
                    || isStaff();
        allow create, update: if isStaff();
        allow delete: if isAdmin();
      }

      match /notes/{document=**} {
        allow read: if isStudentOf(classeId, eleveId)
                    || isParentOf(classeId, eleveId)
                    || isStaff();
        allow write: if isStaff() && !isCaissier();
      }

      match /bulletins/{document=**} {
        allow read: if isStudentOf(classeId, eleveId)
                    || isParentOf(classeId, eleveId)
                    || isStaff();
        allow write: if isStaff() && !isCaissier();
      }

      match /colles/{document=**} {
        allow read: if isStudentOf(classeId, eleveId)
                    || isParentOf(classeId, eleveId)
                    || isStaff();
        allow write: if isStaff() && !isCaissier();
      }
    }

    // ══════════════════════════════════════════════════════════
    // 📰 CMS (À propos, UID-gated)
    // ══════════════════════════════════════════════════════════

    match /cms/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == "ARCosTxTeZYvk9cj548mnRzaYKG2";
    }

    // ══════════════════════════════════════════════════════════
    // 👨‍🏫 TEACHERS & ADMINS
    // ══════════════════════════════════════════════════════════
    //
    // Phase 6g tighten: reads were ANY authenticated user, now staff-
    // only. Eleves don't need to read the prof list; their app surface
    // fetches the specific prof for a note/bulletin author display,
    // which works through the same isStudentOf handshake.
    //
    // Actually: on second look, the eleve UI may legitimately need to
    // show prof names in bulletin headers, etc. Keep read open but
    // note that teachers' emails + passwords are NOT in this doc
    // (Firebase Auth holds those separately and is always access-
    // controlled by Google). The prof doc has nom, prenom, role,
    // classesIds, matieres. Not super sensitive.

    match /professeurs/{userId} {
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.statut == 'en_attente';

      allow update, delete: if isAdmin();
      allow read: if request.auth != null;
    }
  }
}
